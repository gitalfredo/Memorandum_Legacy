<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph"
    app:startDestination="@id/FirstFragment">

    <fragment
        android:id="@+id/FirstFragment"
        android:name="com.alfredoalmenares.memorandum.FirstFragment"
        tools:layout="@layout/fragment_first">

        <action
            android:id="@+id/action_FirstFragment_to_AddFragment"
            app:destination="@id/AddFragment" />
        <action
            android:id="@+id/action_FirstFragment_to_EditFragment"
            app:destination="@id/EditFragment" />
    </fragment>


    <fragment
        android:id="@+id/AddFragment"
        android:name="com.alfredoalmenares.memorandum.AddFragment"
        tools:layout="@layout/addfragment">

        <action
            android:id="@+id/action_AddFragment_to_FirstFragment"
            app:destination="@id/FirstFragment" />
    </fragment>

    <fragment
        android:id="@+id/EditFragment"
        android:name="com.alfredoalmenares.memorandum.EditFragment"
        tools:layout="@layout/edit_fragment">

        <action
            android:id="@+id/action_EditFragment_to_FirstFragment"
            app:destination="@id/FirstFragment" />
    </fragment>
</navigation>